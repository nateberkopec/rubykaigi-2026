<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Presentation (Reading Mode)</title>
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}
html, body {
  width: 100%;
  min-height: 100%;
  background: #f3f3f3;
  color: #000;
  font-family: "Palatino Linotype", Palatino, "Book Antiqua", Georgia, serif;
  -webkit-user-select: none;
  user-select: none;
}
body {
  overflow-y: auto;
}
.deck {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4vh;
  padding: 4vh 2vh;
}
.slide {
  width: min(100%, calc(100vh * 16 / 9));
  aspect-ratio: 16 / 9;
  height: auto;
  flex: none;
  margin: 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #fff;
  overflow: hidden;
  padding: 2vh;
  container-type: size;
}
.slide-content {
  width: 100%;
}
.slide-content.fit-layout {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
h1 {
  font-size: clamp(1.9rem, 4.8cqh, 5rem);
  font-weight: 700;
  margin-bottom: 0.45em;
  line-height: 1.1;
}
h2 {
  font-size: clamp(1.6rem, 3.7cqh, 3.75rem);
  font-weight: 600;
  margin-bottom: 0.4em;
  line-height: 1.15;
}
h3 {
  font-size: clamp(1.3rem, 2.8cqh, 2.75rem);
  font-weight: 600;
  margin-bottom: 0.35em;
  line-height: 1.2;
}
.fit-heading {
  width: 100%;
  margin: 0;
  line-height: 0.9;
  text-align: center;
  text-wrap: balance;
  overflow-wrap: normal;
}
p {
  font-size: clamp(0.95rem, 1.85cqh, 1.9rem);
  line-height: 1.4;
  margin-bottom: 0.7em;
}
ul, ol {
  font-size: clamp(0.95rem, 1.85cqh, 1.9rem);
  line-height: 1.5;
  margin-left: 1.25em;
  margin-bottom: 0.7em;
}
li {
  margin-bottom: 0.25em;
}
strong {
  font-weight: 700;
}
code {
  font-family: "SF Mono", Menlo, monospace;
  background: #f0f0f0;
  padding: 0.1em 0.3em;
  border-radius: 3px;
  font-size: 0.9em;
}
a {
  color: #000;
  text-decoration: underline;
}
@media (max-width: 640px) {
  .slide {
    aspect-ratio: 4 / 3;
    width: min(100%, calc(100vh * 4 / 3));
  }
}
@page {
  size: landscape;
  margin: 12mm;
}
@media print {
  html, body {
    background: #fff;
  }
  .deck {
    display: block;
    padding: 0;
    gap: 0;
  }
  .slide {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    margin: 0;
    overflow: hidden;
    break-inside: avoid;
    page-break-inside: avoid;
    break-after: page;
    page-break-after: always;
  }
  .slide:last-child {
    break-after: auto;
    page-break-after: auto;
  }
}
</style>
</head>
<body><div class="deck"><%= slides %></div><script><%= script %></script></body>
</html>
